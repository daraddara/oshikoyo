        "check-version": "node scripts/check-version.js"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "cross-env": "^10.1.0",
        "fake-indexeddb": "^6.2.5",
        "jsdom": "^23.0.0",
        "playwright": "^1.58.2",
        "serve": "^14.2.6",
        "vitest": "^1.0.0"
    }
}